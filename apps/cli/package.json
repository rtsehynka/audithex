{
  "name": "@audithex/cli",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "audithex": "./bin/audithex.js"
  },
  "files": ["bin", "dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests --dir ./src"
  },
  "dependencies": {
    "@audithex/core-discovery": "workspace:*",
    "@audithex/core-eval-runner": "workspace:*",
    "@audithex/core-i18n": "workspace:*",
    "@audithex/core-payloads": "workspace:*",
    "@audithex/core-report": "workspace:*",
    "@audithex/core-rules": "workspace:*",
    "@audithex/core-types": "workspace:*",
    "@audithex/core-update": "workspace:*",
    "@clack/prompts": "0.9.1",
    "chalk": "5.4.1",
    "commander": "12.1.0",
    "dotenv": "16.4.7",
    "ora": "8.1.1",
    "zod": "3.24.1"
  },
  "devDependencies": {
    "@types/node": "22.10.5",
    "tsx": "4.19.2",
    "typescript": "5.7.2"
  }
}
