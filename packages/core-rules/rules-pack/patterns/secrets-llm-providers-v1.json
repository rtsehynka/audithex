{
  "_id": "secrets-llm-providers-v1",
  "schemaVersion": "0.1",
  "kind": "secret-patterns",
  "source": "Modeled after trufflesecurity/trufflehog detectors (openai, anthropic, google_api_key, etc.). Patterns hand-authored from each provider's published key format; refresh on rules-pack updates.",
  "license": "AGPL-3.0-or-later",
  "entries": [
    {
      "id": "openai-api-key",
      "provider": "openai",
      "description": "OpenAI API key (sk-... prefix)",
      "regex": "\\bsk-(?!ant-)[A-Za-z0-9_-]{20,}\\b",
      "references": [
        "https://platform.openai.com/api-keys",
        "https://github.com/trufflesecurity/trufflehog/blob/main/pkg/detectors/openai"
      ],
      "tags": ["llm", "high-confidence"]
    },
    {
      "id": "openai-project-key",
      "provider": "openai",
      "description": "OpenAI project-scoped API key (sk-proj- prefix)",
      "regex": "\\bsk-proj-[A-Za-z0-9_-]{40,}\\b",
      "tags": ["llm"]
    },
    {
      "id": "anthropic-api-key",
      "provider": "anthropic",
      "description": "Anthropic API key (sk-ant-...)",
      "regex": "\\bsk-ant-[A-Za-z0-9_-]{30,}\\b",
      "references": [
        "https://docs.anthropic.com/en/api/getting-started",
        "https://github.com/trufflesecurity/trufflehog/blob/main/pkg/detectors/anthropic"
      ],
      "tags": ["llm", "high-confidence"]
    },
    {
      "id": "google-api-key",
      "provider": "google",
      "description": "Google Cloud / Generative AI API key (AIza prefix)",
      "regex": "\\bAIza[0-9A-Za-z_-]{35}\\b",
      "references": [
        "https://github.com/trufflesecurity/trufflehog/blob/main/pkg/detectors/gcpapikey"
      ],
      "tags": ["llm", "cloud"]
    },
    {
      "id": "cohere-api-key",
      "provider": "cohere",
      "description": "Cohere API key (40 char hex)",
      "regex": "\\bco-[A-Za-z0-9]{40}\\b",
      "tags": ["llm"]
    },
    {
      "id": "mistral-api-key",
      "provider": "mistral",
      "description": "Mistral La Plateforme API key",
      "regex": "\\b[A-Za-z0-9]{32}\\.[A-Za-z0-9]{32}\\b",
      "tags": ["llm", "lower-confidence"]
    },
    {
      "id": "huggingface-token",
      "provider": "unknown",
      "description": "Hugging Face access token (hf_)",
      "regex": "\\bhf_[A-Za-z0-9]{34,}\\b",
      "references": [
        "https://github.com/trufflesecurity/trufflehog/blob/main/pkg/detectors/huggingface"
      ],
      "tags": ["llm", "model-host"]
    },
    {
      "id": "replicate-token",
      "provider": "unknown",
      "description": "Replicate API token (r8_)",
      "regex": "\\br8_[A-Za-z0-9]{37,}\\b",
      "tags": ["llm", "model-host"]
    },
    {
      "id": "togetherai-token",
      "provider": "unknown",
      "description": "Together AI API token",
      "regex": "\\b[a-f0-9]{64}\\b",
      "tags": ["llm", "lower-confidence"]
    },
    {
      "id": "pinecone-key",
      "provider": "unknown",
      "description": "Pinecone API key",
      "regex": "\\b[a-f0-9]{8}-[a-f0-9]{4}-[a-f0-9]{4}-[a-f0-9]{4}-[a-f0-9]{12}\\b",
      "tags": ["rag", "lower-confidence"]
    },
    {
      "id": "github-classic-pat",
      "provider": "unknown",
      "description": "GitHub classic personal access token (ghp_)",
      "regex": "\\bghp_[A-Za-z0-9]{36}\\b",
      "references": [
        "https://docs.github.com/en/authentication/keeping-your-account-and-data-secure/managing-your-personal-access-tokens"
      ],
      "tags": ["dev-platform"]
    },
    {
      "id": "github-fine-grained-pat",
      "provider": "unknown",
      "description": "GitHub fine-grained personal access token (github_pat_)",
      "regex": "\\bgithub_pat_[A-Za-z0-9_]{72,255}\\b",
      "tags": ["dev-platform"]
    },
    {
      "id": "gitlab-token",
      "provider": "unknown",
      "description": "GitLab personal access token (glpat-)",
      "regex": "\\bglpat-[A-Za-z0-9_-]{20}\\b",
      "tags": ["dev-platform"]
    },
    {
      "id": "slack-bot-token",
      "provider": "unknown",
      "description": "Slack bot token (xoxb-)",
      "regex": "\\bxoxb-[0-9]{10,13}-[0-9]{10,13}-[A-Za-z0-9]{24,32}\\b",
      "tags": ["chat-platform"]
    },
    {
      "id": "slack-user-token",
      "provider": "unknown",
      "description": "Slack user token (xoxp-)",
      "regex": "\\bxoxp-[0-9]{10,13}-[0-9]{10,13}-[0-9]{10,13}-[A-Za-z0-9]{32}\\b",
      "tags": ["chat-platform"]
    },
    {
      "id": "discord-bot-token",
      "provider": "unknown",
      "description": "Discord bot token",
      "regex": "\\b[MN][A-Za-z0-9]{23}\\.[A-Za-z0-9_-]{6}\\.[A-Za-z0-9_-]{27,}\\b",
      "tags": ["chat-platform"]
    },
    {
      "id": "aws-access-key-id",
      "provider": "unknown",
      "description": "AWS Access Key ID (AKIA / ASIA / ABIA prefixes)",
      "regex": "\\b(?:AKIA|ASIA|ABIA|ACCA)[0-9A-Z]{16}\\b",
      "references": ["https://github.com/trufflesecurity/trufflehog/blob/main/pkg/detectors/aws"],
      "tags": ["cloud"]
    },
    {
      "id": "stripe-secret-key",
      "provider": "unknown",
      "description": "Stripe secret key (sk_live_ / sk_test_)",
      "regex": "\\bsk_(?:live|test)_[A-Za-z0-9]{24,}\\b",
      "tags": ["payments"]
    },
    {
      "id": "twilio-account-sid",
      "provider": "unknown",
      "description": "Twilio Account SID (AC + 32 hex)",
      "regex": "\\bAC[a-f0-9]{32}\\b",
      "tags": ["telephony"]
    },
    {
      "id": "sendgrid-api-key",
      "provider": "unknown",
      "description": "SendGrid API key (SG. prefix)",
      "regex": "\\bSG\\.[A-Za-z0-9_-]{22}\\.[A-Za-z0-9_-]{43}\\b",
      "tags": ["email"]
    }
  ]
}
