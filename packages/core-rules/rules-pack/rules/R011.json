        "regex": "`[^`]*\\$\\{\\s*(?:userInput|userMessage|userQuery|userPrompt|user_input|user_message|input|query|prompt|message|userText)\\b[^}]*\\}[^`]*`",
        "messageParamKind": "user-controlled variable interpolated into a template literal inside an AI-context package"
      },
      {
        "id": "py-user-input-in-prompt-template",
        "languages": ["python"],
        "regex": "(?:f\"|f')[^\"'\\n]*\\{\\s*(?:user_input|user_message|user_query|user_prompt|input|query|prompt|message)\\b[^}]*\\}",
        "messageParamKind": "f-string user-controlled variable interpolated inside an AI-context package"
      }
    ]
  },
  "messageKey": "findings:R011.message",
  "rationaleKey": "findings:R011.rationale",
  "fixKey": "findings:R011.fix",
