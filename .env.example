# Audithex configuration. Every line is OPTIONAL — a basic `scan` runs
# end-to-end with no .env at all. Copy this file to `.env` and uncomment
# the variables you need. The CLI validates values with zod at startup
# and fails fast on malformed input.

# ---------------------------------------------------------------------
# LLM keys — only needed for LLM-judge evals and AI-fallback extraction.
# Provide one of the two. The CLI sends requests directly from your
# machine to the provider; nothing is ever forwarded through audithex
# infrastructure.
# ---------------------------------------------------------------------
# ANTHROPIC_API_KEY=sk-ant-api03-...
# OPENAI_API_KEY=sk-...

# ---------------------------------------------------------------------
# Dynamic agent testing. Point this at a running agent endpoint to
# enable the dynamic prompt-injection tester. Both variables must be
# set together — endpoint alone is rejected.
# ---------------------------------------------------------------------
# AUDITHEX_AGENT_ENDPOINT=https://your-agent.example.com/api/chat
# AUDITHEX_AGENT_AUTH=Bearer eyJhbGciOi...

# ---------------------------------------------------------------------
# Per-scan LLM cost cap in USD. Any LLM-using action aborts when the
# token-cost estimate exceeds this value. Default: 1.00.
# ---------------------------------------------------------------------
# AUDITHEX_LLM_COST_CAP_USD=1.00

# ---------------------------------------------------------------------
# Update channel. AUDITHEX_RULES_PACK_URL accepts any git URL — a public
# mirror, a private fork, or a local file:// path during development.
# AUDITHEX_AUTO_UPDATE_CHECK controls the daily silent HEAD probe `scan`
# makes; set it to `false` in offline / air-gapped environments.
# ---------------------------------------------------------------------
# AUDITHEX_RULES_PACK_URL=https://github.com/audithex/rules-pack.git
# AUDITHEX_AUTO_UPDATE_CHECK=true

# ---------------------------------------------------------------------
# UI language. The CLI falls back to LANG / LC_ALL, then to `en`.
# Currently supported: `en`, `uk`.
# ---------------------------------------------------------------------
# AUDITHEX_LOCALE=en

# ---------------------------------------------------------------------
# Per-user audithex root. Holds the rules-pack git checkout, selftest
# history, and update logs. Default: ~/.audithex
# ---------------------------------------------------------------------
# AUDITHEX_HOME=/Users/you/.audithex

# ---------------------------------------------------------------------
# Locales directory override. Only relevant for packaged builds where
# the locales tree has been relocated away from the source layout.
# ---------------------------------------------------------------------
# AUDITHEX_LOCALES_ROOT=/abs/path/to/locales
